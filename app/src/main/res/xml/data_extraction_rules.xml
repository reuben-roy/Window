<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Window stores only local behavioral data — exclude from cloud backup -->
        <exclude domain="database" path="window_db" />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="window_db" />
    </device-transfer>
</data-extraction-rules>

